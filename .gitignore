# Python junk
__pycache__/
*.pyc
*.pyo
*.pyd

# Python environment
.python-version

# pytest cache (if you ever use it)
.pytest_cache/

# mypy / type checking
.mypy_cache/

# coverage reports
.coverage
htmlcov/

# Virtual environments
venv/
.env/
.env

# Prevent accidental weird filenames / debug junk
*.bak
*.swp
*.orig

# Builds/logs/temp
build/
dist/
*.log
*.tmp

# OS junk
.DS_Store
Thumbs.db

# IDE
.vscode/

# Scratch testing
test/
water_test/

# Archives / backups
*.zip
archive/
legacy/
*/backup/
*/archive/
data/backup/
git_notes/

# Third-party binaries / local installs
engine/

# Large game assets - keep out of first GitHub push
assets/

# Game saves
saves/

# Ignore temporary validation scripts only
tools/validate*.py
